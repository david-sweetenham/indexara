FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir -e . && pip install --no-cache-dir uvicorn[standard]

COPY indexara/ indexara/

EXPOSE 8000

ENV INDEXARA_CATALOG_DB_PATH=/data/catalog.db
ENV INDEXARA_SEARCH_DB_PATH=/data/search.db

CMD ["python", "-m", "indexara.server.main"]
